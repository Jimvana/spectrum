{
  "manifest_version": 3,
  "name": "Spectrum .spec Viewer",
  "version": "1.1.0",
  "description": "Open current .spec files directly in Chrome: decoded and syntax-highlighted, no external tools needed.",

  "action": {
    "default_popup": "popup.html",
    "default_title": "Spectrum .spec Viewer",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "permissions": [
    "declarativeNetRequest",
    "tabs",
    "webNavigation",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "web_accessible_resources": [
    {
      "resources": ["viewer.html", "viewer.js", "wiki.html", "wiki.js", "dictionary.js", "spec-decoder.js", "spec-tokens.json", "lib/*"],
      "matches": ["<all_urls>"]
    }
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
